# Database
DB_USER=app
DB_PASSWORD=app
DB_NAME=app
DB_PORT=5432

# App
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=super-secret-jwt-key-2024
JWT_EXPIRES_IN=30d

# Rewards
CYCLE_BEHAVIOR=reset
REWARD_COOLDOWN_SEC=300
REWARD_STREAK_RESET_SEC=600

# POSTGRES_USER: ${DB_USER:-app}
# POSTGRES_PASSWORD: ${DB_PASSWORD:-app}
# POSTGRES_DB: ${DB_NAME:-app}
DATABASE_URL=postgresql://app:app@localhost:5432/app
