# Database
DB_USER=app
DB_PASSWORD=app
DB_NAME=app
DB_PORT=5432

# App
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=super-secret-jwt-key-2026
JWT_EXPIRES_IN=30d

# Rewards
CYCLE_BEHAVIOR=fixed
REWARD_COOLDOWN_SEC=20
REWARD_STREAK_RESET_SEC=60

# POSTGRES_USER: ${DB_USER:-app}
# POSTGRES_PASSWORD: ${DB_PASSWORD:-app}
# POSTGRES_DB: ${DB_NAME:-app}
DATABASE_URL=postgresql://app:app@postgres:5432/app
